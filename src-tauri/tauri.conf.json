{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Barrekeep",
  "version": "0.1.5",
  "identifier": "com.barrekeep.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Barrekeep",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDg5NkY3OTgxRTI5M0RDQjEKUldTeDNKUGlnWGx2aWErempBbGlKTlo3Uk0wRG1MaWVTNUErMzFQUkkyNTRzNE9LeWR4ZlNidTgK",
      "endpoints": [
        "https://github.com/NaturalStateOfDev/barrekeep/releases/latest/download/latest.json"
      ]
    }
  }
}
